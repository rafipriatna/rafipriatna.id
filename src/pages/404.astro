---
import GameLayout from "@layouts/GameLayout.astro";
---

<GameLayout title="404 - Lost" description="This page doesn't exist">
  <div class="min-h-screen pb-24 flex items-center justify-center">
    <div class="max-w-md mx-auto px-4 text-center">
      <div class="rpg-box p-8">
        <div class="text-6xl mb-4">🗺️</div>
        <h1 class="font-pixel text-base sm:text-lg text-[var(--ink)] mb-4">
          YOU ARE LOST
        </h1>
        <p class="font-mono text-sm text-[var(--ink-light)] mb-6">
          This area hasn't been discovered yet. The path fades into mist...
        </p>
        <a href="/" class="pixel-btn inline-block no-underline">
          ← Return to Village
        </a>
      </div>
    </div>
  </div>
</GameLayout>