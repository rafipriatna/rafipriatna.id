---
import { type CollectionEntry, getCollection } from "astro:content";
import GameLayout from "@layouts/GameLayout.astro";
import QuestJournal from "@components/QuestJournal.astro";

export async function getStaticPaths() {
  const allWriteups = (await getCollection("writeups"))
    .filter((w) => !w.data.draft)
    .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
  return allWriteups.map((writeup) => ({
    params: { slug: writeup.slug },
    props: writeup,
  }));
}

type Props = CollectionEntry<"writeups">;

const writeup = Astro.props;
const { Content, headings } = await writeup.render();
---

<GameLayout title={writeup.data.title} description={writeup.data.description}>
  <QuestJournal
    title={writeup.data.title}
    description={writeup.data.description}
    date={writeup.data.date}
    body={writeup.body}
    headings={headings}
    contentType="writeups"
    backHref="/writeups"
    backLabel="Detective Office"
  >
    <Content />
  </QuestJournal>
</GameLayout>