---
import { SITE, SOCIALS } from "@consts";
import { getCollection } from "astro:content";

const blog = (await getCollection("blog"))
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);

const writeups = (await getCollection("writeups"))
  .filter((w) => !w.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 2);

const notes = (await getCollection("notes"))
  .filter((n) => !n.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 2);
---

<div class="village-scene min-h-screen pb-4">

  <!-- === HERO SECTION === -->
  <section class="hero-section relative max-w-4xl mx-auto px-4 pt-8 sm:pt-16 pb-8 text-center">
    <!-- Pixel art decorative lights -->
    <div class="flex justify-center gap-3 mb-6 animate-fade-in" style="animation-delay: 0.1s;">
      <div class="w-2 h-2 bg-[var(--green-glow)] shadow-[0_0_6px_2px_var(--green-glow)]"></div>
      <div class="w-2 h-2 bg-[var(--gold)] shadow-[0_0_6px_2px_var(--gold)]"></div>
      <div class="w-2 h-2 bg-[var(--lab-accent)] shadow-[0_0_6px_2px_var(--lab-accent)]"></div>
      <div class="w-2 h-2 bg-[var(--detective-string)] shadow-[0_0_6px_2px_var(--detective-string)]"></div>
      <div class="w-2 h-2 bg-[var(--green-glow)] shadow-[0_0_6px_2px_var(--green-glow)]"></div>
    </div>

    <!-- Terminal-style title -->
    <div class="inline-block pixel-border px-5 py-3 sm:px-8 sm:py-4 bg-[var(--bg-card)] animate-slide-in-up">
      <h1 class="font-pixel text-lg sm:text-2xl md:text-3xl text-[var(--ink)] leading-relaxed tracking-wide">
        RAFI PRIATNA
      </h1>
      <p class="font-mono text-sm sm:text-base text-[var(--gold)] mt-2">
        Application Security Engineer
      </p>
      <p class="font-mono text-xs sm:text-sm text-[var(--ink-muted)] mt-1">
        _exploring the digital frontier_
      </p>
    </div>

    <!-- Quick stats row -->
    <div class="flex flex-wrap items-center justify-center gap-3 sm:gap-6 mt-6 animate-slide-in-up" style="animation-delay: 0.3s;">
      <div class="flex items-center gap-1.5">
        <span class="font-mono text-xs text-[var(--ink-muted)]">📄</span>
        <span class="font-mono text-sm text-[var(--ink)]">{blog.length + 20}+ articles</span>
      </div>
      <div class="w-px h-4 bg-[var(--border)]"></div>
      <div class="flex items-center gap-1.5">
        <span class="font-mono text-xs text-[var(--ink-muted)]">📓</span>
        <span class="font-mono text-sm text-[var(--ink)]">{notes.length + 10}+ notes</span>
      </div>
      <div class="w-px h-4 bg-[var(--border)]"></div>
      <div class="flex items-center gap-1.5">
        <span class="font-mono text-xs text-[var(--ink-muted)]">🔍</span>
        <span class="font-mono text-sm text-[var(--ink)]">{writeups.length + 5}+ writeups</span>
      </div>
    </div>

    <!-- Short bio -->
    <p class="font-sans text-sm sm:text-base text-[var(--ink-light)] max-w-xl mx-auto mt-6 leading-relaxed animate-slide-in-up" style="animation-delay: 0.4s;">
      Cybersecurity researcher, bug hunter, and lifelong learner. 
      Documenting the journey through technical deep-dives, capture-the-flag writeups, and personal notes.
    </p>
  </section>

  <!-- === VILLAGE MAP SECTION === -->
  <section class="max-w-4xl mx-auto px-4 mt-6 sm:mt-10">
    <div class="text-center mb-6">
      <span class="font-pixel text-[10px] text-[var(--ink-muted)]">▼ EXPLORE THE WORLD ▼</span>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 sm:gap-6">
      <!-- Research Lab -->
      <a href="/blog" class="group block pixel-border p-4 sm:p-5 bg-[var(--bg-card)] hover:bg-[var(--bg-card-hover)] transition-all duration-200 no-underline">
        <div class="flex items-center gap-3 mb-3">
          <div class="w-10 h-10 pixel-border flex items-center justify-center text-lg"
               style="background: var(--lab-dark); border-color: var(--lab-metal);">
            <span>🔬</span>
          </div>
          <div>
            <h2 class="font-pixel text-[10px] text-[var(--lab-glow)] group-hover:text-[var(--green-glow)] transition-colors">
              RESEARCH LAB
            </h2>
            <p class="font-mono text-xs text-[var(--ink-muted)]">Technology Articles</p>
          </div>
        </div>
        <p class="font-sans text-sm text-[var(--ink-light)]/80 leading-relaxed">
          Long-form technical content about cybersecurity, app security, reverse engineering, and development.
        </p>
        <div class="mt-3 flex items-center gap-2">
          <span class="font-mono text-xs text-[var(--green-glow)]">{blog.length}+ documents</span>
          <span class="text-[var(--ink-dim)]">→</span>
        </div>
      </a>

      <!-- Cozy Cabin -->
      <a href="/notes" class="group block pixel-border p-4 sm:p-5 bg-[var(--bg-card)] hover:bg-[var(--bg-card-hover)] transition-all duration-200 no-underline">
        <div class="flex items-center gap-3 mb-3">
          <div class="w-10 h-10 pixel-border flex items-center justify-center text-lg"
               style="background: var(--cabin-wall); border-color: var(--border);">
            <span>🏡</span>
          </div>
          <div>
            <h2 class="font-pixel text-[10px] text-[var(--cabin-warm)] group-hover:text-[var(--gold)] transition-colors">
              COZY CABIN
            </h2>
            <p class="font-mono text-xs text-[var(--ink-muted)]">Personal Notes</p>
          </div>
        </div>
        <p class="font-sans text-sm text-[var(--ink-light)]/80 leading-relaxed">
          Casual thoughts, experiments, productivity tips, life updates, and behind-the-scenes discoveries.
        </p>
        <div class="mt-3 flex items-center gap-2">
          <span class="font-mono text-xs text-[var(--cabin-warm)]">{notes.length}+ entries</span>
          <span class="text-[var(--ink-dim)]">→</span>
        </div>
      </a>

      <!-- Detective Office -->
      <a href="/writeups" class="group block pixel-border p-4 sm:p-5 bg-[var(--bg-card)] hover:bg-[var(--bg-card-hover)] transition-all duration-200 no-underline">
        <div class="flex items-center gap-3 mb-3">
          <div class="w-10 h-10 pixel-border flex items-center justify-center text-lg"
               style="background: var(--detective-board); border-color: var(--border);">
            <span>🔍</span>
          </div>
          <div>
            <h2 class="font-pixel text-[10px] text-[var(--detective-string)] group-hover:text-[var(--gold)] transition-colors">
              DETECTIVE OFFICE
            </h2>
            <p class="font-mono text-xs text-[var(--ink-muted)]">Writeups & Case Files</p>
          </div>
        </div>
        <p class="font-sans text-sm text-[var(--ink-light)]/80 leading-relaxed">
          Bug bounty reports, vulnerability analysis, CTF walkthroughs, and security case studies.
        </p>
        <div class="mt-3 flex items-center gap-2">
          <span class="font-mono text-xs text-[var(--detective-string)]">{writeups.length}+ case files</span>
          <span class="text-[var(--ink-dim)]">→</span>
        </div>
      </a>
    </div>
  </section>

  <!-- === Recent Content === -->
  <section class="max-w-4xl mx-auto px-4 mt-8 sm:mt-12">
    <div class="rpg-box p-4 sm:p-6">
      <h3 class="font-pixel text-[10px] text-[var(--ink-muted)] mb-4">📋 RECENT ACTIVITY</h3>
      
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 sm:gap-6">
        <!-- Articles -->
        <div>
          <div class="flex items-center gap-2 mb-3 pb-2 border-b border-[var(--border)]">
            <span class="font-mono text-xs text-[var(--green-glow)]">🔬 latest research</span>
          </div>
          {blog.length > 0 ? (
            <ul class="space-y-2">
              {blog.map((post) => (
                <li>
                  <a href={`/${post.slug}`} 
                     class="block font-mono text-sm text-[var(--ink-light)] hover:text-[var(--gold)] transition-colors truncate no-underline">
                    <span class="text-[var(--ink-dim)]">&gt;</span> {post.data.title}
                  </a>
                  <span class="font-mono text-[10px] text-[var(--ink-dim)]">
                    {post.data.date.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}
                  </span>
                </li>
              ))}
            </ul>
          ) : (
            <p class="font-mono text-xs text-[var(--ink-dim)] italic">No data yet...</p>
          )}
          <a href="/blog" class="inline-block mt-2 font-mono text-xs text-[var(--green-glow)] hover:text-[var(--gold)] transition-colors no-underline">
            view all →
          </a>
        </div>

        <!-- Notes -->
        <div>
          <div class="flex items-center gap-2 mb-3 pb-2 border-b border-[var(--border)]">
            <span class="font-mono text-xs text-[var(--cabin-warm)]">🏡 recent journal</span>
          </div>
          {notes.length > 0 ? (
            <ul class="space-y-2">
              {notes.map((note) => (
                <li>
                  <a href={`/notes/${note.slug}`} 
                     class="block font-mono text-sm text-[var(--ink-light)] hover:text-[var(--gold)] transition-colors truncate no-underline">
                    <span class="text-[var(--ink-dim)]">&gt;</span> {note.data.title}
                  </a>
                  <span class="font-mono text-[10px] text-[var(--ink-dim)]">
                    {note.data.date.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}
                  </span>
                </li>
              ))}
            </ul>
          ) : (
            <p class="font-mono text-xs text-[var(--ink-dim)] italic">Empty pages...</p>
          )}
          <a href="/notes" class="inline-block mt-2 font-mono text-xs text-[var(--cabin-warm)] hover:text-[var(--gold)] transition-colors no-underline">
            open journal →
          </a>
        </div>

        <!-- Writeups -->
        <div>
          <div class="flex items-center gap-2 mb-3 pb-2 border-b border-[var(--border)]">
            <span class="font-mono text-xs text-[var(--detective-string)]">🔍 recent cases</span>
          </div>
          {writeups.length > 0 ? (
            <ul class="space-y-2">
              {writeups.map((w) => (
                <li>
                  <a href={`/writeups/${w.slug}`} 
                     class="block font-mono text-sm text-[var(--ink-light)] hover:text-[var(--gold)] transition-colors truncate no-underline">
                    <span class="text-[var(--ink-dim)]">&gt;</span> {w.data.title}
                  </a>
                  <span class="font-mono text-[10px] text-[var(--ink-dim)]">
                    {w.data.date.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}
                  </span>
                </li>
              ))}
            </ul>
          ) : (
            <p class="font-mono text-xs text-[var(--ink-dim)] italic">No open cases...</p>
          )}
          <a href="/writeups" class="inline-block mt-2 font-mono text-xs text-[var(--detective-string)] hover:text-[var(--gold)] transition-colors no-underline">
            investigate more →
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- === Contact / Social CTA === -->
  <section class="max-w-xl mx-auto px-4 mt-8 sm:mt-12 pb-8 text-center">
    <div class="pixel-border p-4 sm:p-5 bg-[var(--bg-card)]">
      <p class="font-mono text-sm text-[var(--ink-light)] mb-4">
        Want to connect? Find me on the web.
      </p>
      <div class="flex items-center justify-center gap-6 sm:gap-8">
        {SOCIALS.map((s) => (
          <a href={s.HREF} target="_blank" rel="noopener noreferrer"
             class="font-mono text-sm text-[var(--ink-muted)] hover:text-[var(--gold)] transition-colors duration-200 no-underline">
            {s.NAME.toLowerCase()}
          </a>
        ))}
        <a href="mailto:me@rafipriatna.id"
           class="font-mono text-sm text-[var(--gold)] hover:text-[var(--gold-hover)] transition-colors duration-200 no-underline">
          email
        </a>
      </div>
    </div>
  </section>
</div>

<style is:global>
  @keyframes cursorBlink {
    50% { opacity: 0; }
  }
  .animate-cursor-blink {
    animation: cursorBlink 1.2s step-end infinite;
  }
</style>