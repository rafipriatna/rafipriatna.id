---
// Cozy Cabin - journal/diary interface for notes
import { type CollectionEntry, getCollection } from "astro:content";

const data = (await getCollection("notes"))
  .filter((note) => !note.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

type Acc = { [year: string]: CollectionEntry<"notes">[] };
const notes = data.reduce((acc: Acc, note) => {
  const year = note.data.date.getFullYear().toString();
  if (!acc[year]) acc[year] = [];
  acc[year].push(note);
  return acc;
}, {});
const years = Object.keys(notes).sort((a, b) => parseInt(b) - parseInt(a));

const readingTime = (body: string) => {
  const wpm = 200;
  const words = body?.split(/\s+/g).length || 0;
  const time = Math.ceil(words / wpm);
  return `${time} min read`;
};
---

<div class="cabin-page min-h-screen pb-24">
  <!-- Header -->
  <div class="max-w-4xl mx-auto px-4 pt-8 sm:pt-12">
    <div class="flex items-center gap-3 mb-2">
      <span class="font-pixel text-sm text-[var(--ink)] animate-fade-in">🏡</span>
      <h1 class="font-pixel text-lg sm:text-xl text-[var(--ink)] animate-slide-in-up">
        COZY CABIN
      </h1>
    </div>
    <p class="font-mono text-sm sm:text-base text-[var(--ink-light)] ml-9 animate-slide-in-up" style="animation-delay: 0.1s;">
      Personal journal · Thoughts · Behind the scenes · Life updates
    </p>
    
    <!-- Back link -->
    <a href="/" class="inline-flex items-center gap-1 mt-4 font-mono text-sm text-[var(--ink-muted)] hover:text-[var(--gold)] transition-colors">
      ← Return to village
    </a>
  </div>

  <!-- Journal / Desk -->
  <div class="max-w-4xl mx-auto px-4 mt-6">
    <div class="relative">
      <!-- Journal book -->
      <div class="rpg-box p-4 sm:p-6 sm:p-8 relative">
        <!-- Book spine -->
        <div class="absolute left-0 top-0 bottom-0 w-6"
             style="background: linear-gradient(90deg, var(--wood-dark) 0%, var(--wood) 100%); border-right: 2px solid var(--border);">
          <div class="h-full flex items-center justify-center">
            <span class="font-pixel text-[6px] text-[var(--ink)]" style="writing-mode: vertical-rl;">JOURNAL</span>
          </div>
        </div>
        
        <!-- Page header -->
        <div class="ml-4">
          <div class="flex items-center gap-2 mb-4">
            <span class="font-mono text-xs text-[var(--ink-dim)]">📖</span>
            <span class="font-pixel text-[8px] text-[var(--ink)]">PERSONAL JOURNAL</span>
            <span class="font-mono text-xs text-[var(--ink-dim)] ml-auto">{data.length} entries</span>
          </div>
          
          <!-- Divider -->
          <div class="h-px mb-6" style="background: repeating-linear-gradient(90deg, var(--border) 0, var(--border) 4px, transparent 4px, transparent 8px);"></div>
        </div>

        <div class="ml-4 space-y-8">
          {years.map((year) => (
            <div>
              <div class="flex items-center gap-2 mb-4">
                <span class="font-mono text-base text-[var(--ink)] font-bold">{year}</span>
                <span class="font-mono text-xs text-[var(--ink-dim)]">{notes[year].length} pages</span>
              </div>
              
              <div class="space-y-4">
                {notes[year].map((note) => (
                  <a href={`/notes/${note.slug}`}
                     class="journal-entry group block relative pl-4 border-l-2 border-dotted border-[var(--border)] hover:border-[var(--gold)] transition-colors no-underline">
                    <!-- Page curl decoration -->
                    <div class="absolute -left-[5px] top-1 w-2 h-2 bg-[var(--gold)]/30 group-hover:bg-[var(--gold)] transition-colors rotate-45"></div>
                    
                    <div class="pb-3">
                      <div class="flex items-start justify-between gap-3">
                        <h3 class="font-mono text-sm sm:text-base text-[var(--ink)] font-bold group-hover:text-[var(--gold)] transition-colors">
                          {note.data.title}
                        </h3>
                        <span class="font-mono text-[11px] text-[var(--ink-dim)] shrink-0">
                          {note.data.date.toLocaleDateString('en-US', { day: 'numeric', month: 'short', year: 'numeric' })}
                        </span>
                      </div>
                      
                      {note.data.description && (
                        <p class="font-sans text-xs sm:text-sm text-[var(--ink-light)]/80 mt-1 line-clamp-2">
                          {note.data.description}
                        </p>
                      )}
                      
                      <span class="font-mono text-[10px] text-[var(--ink-dim)] mt-1 inline-block">
                        ~{readingTime(note.body)}
                      </span>
                    </div>
                  </a>
                ))}
              </div>
            </div>
          ))}
        </div>
        
        {data.length === 0 && (
          <div class="ml-4 text-center py-12">
            <span class="font-mono text-sm text-[var(--ink-dim)] italic">
              The journal pages are blank... waiting to be written.
            </span>
          </div>
        )}
      </div>
    </div>
  </div>

  <!-- Bottom nav -->
  <div class="max-w-4xl mx-auto px-4 mt-8 text-center">
    <a href="/" class="font-mono text-sm text-[var(--ink-muted)] hover:text-[var(--gold)] transition-colors">
      ← Back to village center
    </a>
  </div>
</div>