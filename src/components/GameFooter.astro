---
import { SITE, SOCIALS } from "@consts";
---

<footer class="game-footer relative z-10 mt-8">
  <div class="max-w-4xl mx-auto px-4 py-6 flex flex-col sm:flex-row items-center justify-between gap-3">
    <p class="font-mono text-sm text-[var(--ink-muted)]">
      &copy; {new Date().getFullYear()} {SITE.TITLE}
    </p>
    <div class="flex items-center gap-4 font-mono text-sm">
      {SOCIALS.map((s, i) => (
        <>
          <a 
            href={s.HREF}
            target="_blank"
            rel="noopener noreferrer"
            class="text-[var(--ink-muted)] hover:text-[var(--gold)] transition-colors duration-200 no-underline"
            aria-label={`${SITE.TITLE} on ${s.NAME}`}
          >
            {s.NAME.toLowerCase()}
          </a>
          {i < SOCIALS.length - 1 && <span class="text-[var(--ink-dim)]">·</span>}
        </>
      ))}
    </div>
  </div>
</footer>

<style is:global>
  .game-footer {
    border-top: 1px solid var(--border);
    background: var(--bg-card);
  }
</style>