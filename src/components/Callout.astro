---
type Props = {
  type?: "info" | "warning" | "tip";
};

const { type = "info" } = Astro.props;

const styles: Record<string, { border: string; bg: string; icon: string; label: string }> = {
  info: { border: "var(--lab-glow)", bg: "rgba(74, 222, 128, 0.1)", icon: "ℹ️", label: "INFO" },
  warning: { border: "var(--gold)", bg: "rgba(232, 168, 56, 0.1)", icon: "⚠️", label: "WARNING" },
  tip: { border: "var(--detective-string)", bg: "rgba(245, 158, 11, 0.08)", icon: "💡", label: "TIP" },
};

const s = styles[type];
---

<div class="pixel-border-light px-4 py-3 my-6" style="border-left: 4px solid var(--gold); border-color: s.border; background: s.bg;">
  <div class="flex items-start gap-2">
    <span class="font-mono text-xs text-[var(--ink-light)]/60 shrink-0 mt-0.5">{s.icon}</span>
    <div>
      <slot />
    </div>
  </div>
</div>